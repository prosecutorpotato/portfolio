# Dependencies
node_modules
/.pnp
.pnp.js

# Build output
dist
dist-ssr
build

# Environment
.env
.env*.local

# SQLite database binaries (generated by Prisma + build script)
# Keep prisma/profile.db ignored (build artifact), but commit
# public/profile.db + public/sql-wasm.wasm for GitHub Pages CI deploy
*.db
*.sqlite
prisma/profile.db
!public/profile.db
!public/sql-wasm.wasm

# Misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Personal documents — never commit resume or sensitive files
*.pdf
*.gdoc

# Editor
.vscode/*
!.vscode/extensions.json
.idea

# TypeScript
*.tsbuildinfo

# Vite
.vite

# Local repo config (contains internal repo names)
prisma/repos.local.ts

# Build-time only files (not needed for CI deploy — DB is pre-built and committed)
prisma/seed.ts
prisma/analyze-commits.ts
prisma/commit-classifier.ts
prisma/repos.local.example.ts
scripts/
docs/
CONTEXT.md
manual_steps.md
local_readme.md