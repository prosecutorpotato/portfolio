generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../prisma/profile.db"
}

model Role {
  id          Int      @id
  company     String
  title       String
  startDate   String   @map("start_date")
  endDate     String?  @map("end_date")
  location    String
  description String
  isCurrent   Boolean  @default(false) @map("is_current")
  achievements String  @default("[]")
  events      TimelineEvent[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("roles")
}

model TimelineEvent {
  id          Int     @id
  roleId      Int?    @map("role_id")
  eventType   String  @map("event_type")
  date        String
  title       String
  description String
  company     String?
  role        Role?   @relation(fields: [roleId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("timeline_events")
}

model Tool {
  id         Int    @id
  name       String
  category   String
  proficiency Int   @default(3)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("tools")
}

model Skill {
  id         Int    @id
  name       String
  category   String
  proficiency Int   @default(3)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("skills")
}

model Education {
  id          Int     @id
  institution String
  qualification String
  startDate   String  @map("start_date")
  endDate     String  @map("end_date")
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("education")
}

model Award {
  id          Int     @id
  title       String
  issuer      String
  date        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("awards")
}

model Project {
  id               Int      @id
  name             String
  description      String
  organisation     String
  languages        String   @map("languages")
  category         String
  contributionRole String   @map("contribution_role")
  lastCommitDate   String   @map("last_commit_date")
  firstCommitDate  String   @map("first_commit_date")
  myCommits        Int      @map("my_commits")
  totalCommits     Int      @map("total_commits")
  isFork           Boolean  @default(false) @map("is_fork")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("projects")
}

// ── Commit-level analysis (powers the force-directed graph) ────────

model Commit {
  id           Int      @id @default(autoincrement())
  repo         String
  hash         String
  date         String
  message      String
  filesChanged String   @map("files_changed") // JSON array of file paths
  insertions   Int      @default(0)
  deletions    Int      @default(0)
  tags         CommitTag[]
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([repo, hash])
  @@map("commits")
}

model CommitTag {
  id        Int    @id @default(autoincrement())
  commitId  Int    @map("commit_id")
  commit    Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)
  category  String // 'tech_stack' | 'framework' | 'language' | 'role' | 'theme'
  value     String // e.g. 'Snowflake', 'Python', 'Analytics Engineer'
  weight    Float  @default(1.0) // confidence / relevance weight

  @@index([commitId])
  @@index([category, value])
  @@map("commit_tags")
}

// ── Pre-computed graph topology (derived from commit tags) ─────────

model GraphNode {
  id        Int      @id @default(autoincrement())
  nodeId    String   @map("node_id")   // unique slug e.g. 'tool-python'
  name      String
  group     String                     // e.g. 'Languages', 'Snowflake'
  type      String                     // 'hub' | 'tool' | 'feature'
  weight    Float    @default(1.0)
  commitCount Int     @default(0) @map("commit_count")
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([nodeId])
  @@map("graph_nodes")
}

model GraphLink {
  id       Int    @id @default(autoincrement())
  source   String @map("source") // node_id
  target   String @map("target") // node_id
  strength Float  @default(0.5)
  kind     String @default("related") // 'membership' | 'related' | 'cooccurrence'
  cooccurrence Int @default(0) @map("cooccurrence")

  @@unique([source, target, kind])
  @@map("graph_links")
}